# QQ 邮箱 SMTP 配置
# 复制为 .env 并填入真实值（不要提交 .env）

# === 发件人 ===
FROM_ADDR=your_email@qq.com
FROM_PASSWORD=your_auth_code_here

# === 收件人（多个用逗号分隔）===
TO_ADDR=recipient@qq.com

# === 可选：抄送 ===
CC_ADDR=

# === SMTP 服务器 ===
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587

# === 可选：默认正文 ===
# SUBJECT=每日简报
# BODY_FILE=today_brief.html
# BODY_TYPE=html